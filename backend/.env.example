# --- Server ---
PORT=3000

# --- Database (matches docker-compose.yml) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=builder
DB_PASSWORD=builder_pass
DB_DATABASE=website_builder
# Dev convenience: auto-create schema from entities. Use migrations in prod.
DB_SYNCHRONIZE=true

# --- Mail (Nodemailer) ---
# For local dev, leave host empty to log emails to the console instead of sending.
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="Website Builder <no-reply@example.com>"

# Public base URL of the frontend (used in emails/links).
PUBLIC_WEB_URL=http://localhost:4200
